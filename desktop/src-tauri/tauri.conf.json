{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DotAbyssPlayer",
  "version": "0.1.0",
  "identifier": "com.dotabyss.player",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ドットアビス 剧情播放器",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "resources/backend": "backend",
      "resources/bin": "bin"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
